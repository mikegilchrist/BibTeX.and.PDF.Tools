#!/bin/bash
# ============================================================================
# Script:       summarize.files
# Version:      1.5.0
# Created:      2026-05-01
# Revised:      2026-07-12
# Purpose:      Generate .txt extracts and/or summary .md files for PDFs
#               or text files, storing results in <out-dir>/Extracts/ and
#               <out-dir>/Summaries/ with YAML frontmatter documenting
#               provenance (source, prompt file, model, date).
#
# Standalone tool -- no dependency on any other script in this repo.
# Called as a subprocess by update.bib.py/update.bib.sh, but --out-dir
# lets any other tool point it at its own directory instead of
# ~/References (e.g. a course repo's own materials directory).
#
# Usage:        summarize.files [OPTIONS] FILE [FILE ...]
# Input:        PDF, .txt, or .md files
# Output:       <out-dir>/Extracts/<base>.txt
#               <out-dir>/Summaries/summary_<base>.md
#
# Options:
#   --out-dir DIR    Base output directory (default: ~/References)
#   --no-summary     Extract text only, skip summary generation
#   --no-extract     Generate summary only, skip text extraction
#   --prompt-file F  Path to plain-text prompt file (default: built-in generic)
#   --model M        Claude model ID (default: claude-haiku-4-5-20251001)
#   -b, --batch      Non-interactive; skip existing files with a warning
#   -f, --force      Overwrite existing files without prompting (implies batch)
#   -n, --dry-run    Show what would be done without making changes
#   -v, --verbose    Show detailed output
#   -h, --help       Show this help message
#
# Requirements:
#   - pdftotext (poppler-utils)
#   - claude CLI
#
# Session:      S26b Cancer Evolution prep
# AI Model:     Claude Sonnet 4.6 / Claude Sonnet 5
# Attribution:  Generated by Michael Gilchrist in collaboration with
#               Claude Sonnet 4.6 / Sonnet 5
# ============================================================================

set -o pipefail

# --- Color output ---
if [[ -t 1 ]]; then
    RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m'
    BLUE='\033[0;34m' NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

ok()   { echo -e "  ${GREEN}ok${NC}  $*"; }
warn() { echo -e "  ${YELLOW}warn${NC} $*"; }
err()  { echo -e "  ${RED}err${NC}  $*" >&2; }

# --- Built-in generic prompt ---
DEFAULT_PROMPT="Write a concise summary (200-400 words) of the following article or document. Cover: main findings or claims, study design or methods (briefly), and broader significance. Use clear prose, not bullet points."

# --- Defaults ---
DO_TXT=1
DO_SUMMARY=1
PROMPT_FILE=""
MODEL="claude-haiku-4-5-20251001"
OUT_DIR="$HOME/References"
BATCH=0
FORCE=0
DRYRUN=0
VERBOSE=0
FILES=()

# --- Parse options ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --out-dir)       OUT_DIR="$2"; shift 2 ;;
        --out-dir=*)     OUT_DIR="${1#*=}"; shift ;;
        --no-summary)    DO_SUMMARY=0; shift ;;
        --no-extract)    DO_TXT=0; shift ;;
        --prompt-file)   PROMPT_FILE="$2"; shift 2 ;;
        --prompt-file=*) PROMPT_FILE="${1#*=}"; shift ;;
        --model)         MODEL="$2"; shift 2 ;;
        --model=*)       MODEL="${1#*=}"; shift ;;
        -b|--batch)      BATCH=1; shift ;;
        -f|--force)      FORCE=1; BATCH=1; shift ;;
        -n|--dry-run)    DRYRUN=1; shift ;;
        -v|--verbose)    VERBOSE=1; shift ;;
        -h|--help)
            echo "Usage: $(basename "$0") [OPTIONS] FILE [FILE ...]"
            echo ""
            echo "Generate .txt extracts and/or summary .md files for PDFs or text files."
            echo "Results go to <out-dir>/Extracts/ and <out-dir>/Summaries/."
            echo ""
            echo "Options:"
            echo "  --out-dir DIR    Base output directory (default: ~/References)"
            echo "  --no-summary     Extract text only, skip summary generation"
            echo "  --no-extract     Generate summary only, skip text extraction"
            echo "  --prompt-file F  Path to plain-text prompt file (default: built-in)"
            echo "  --model M        Claude model ID (default: claude-haiku-4-5-20251001)"
            echo "  -b, --batch      Non-interactive; skip existing files with a warning"
            echo "  -f, --force      Overwrite existing files without prompting"
            echo "  -n, --dry-run    Show what would be done without making changes"
            echo "  -v, --verbose    Show detailed output"
            echo "  -h, --help       Show this help message"
            exit 0
            ;;
        -*)
            err "Unknown option: $1"
            exit 1
            ;;
        *)
            FILES+=("$1"); shift ;;
    esac
done

if [[ ${#FILES[@]} -eq 0 ]]; then
    err "No input files specified."
    echo "Usage: $(basename "$0") [OPTIONS] FILE [FILE ...]"
    exit 1
fi

# --- Validate prompt file ---
if [[ -n "$PROMPT_FILE" && ! -f "$PROMPT_FILE" ]]; then
    err "Prompt file not found: $PROMPT_FILE"
    exit 1
fi

PROMPT_LABEL="${PROMPT_FILE:-built-in}"

# --- Resolve model shorthands ---
case "$MODEL" in
    haiku)  MODEL="claude-haiku-4-5-20251001" ;;
    sonnet) MODEL="claude-sonnet-4-6" ;;
    opus)   MODEL="claude-opus-4-7" ;;
esac

# --- Output directories ---
EXTRACTS_DIR="$OUT_DIR/Extracts"
SUMMARIES_DIR="$OUT_DIR/Summaries"

if [[ $DRYRUN -eq 0 ]]; then
    mkdir -p "$EXTRACTS_DIR" "$SUMMARIES_DIR"
fi

# --- Helper: prompt overwrite or skip ---
# Returns 0 if should proceed, 1 if should skip
should_write() {
    local DEST="$1"
    if [[ ! -f "$DEST" ]]; then return 0; fi
    if [[ $FORCE -eq 1 ]]; then
        [[ $VERBOSE -eq 1 ]] && warn "Overwriting (--force): $DEST"
        return 0
    fi
    if [[ $BATCH -eq 1 ]]; then
        warn "Skipping existing file (use -f to overwrite): $(basename "$DEST")"
        return 1
    fi
    echo -n "  Overwrite $(basename "$DEST")? [y/N] "
    read -r ANS
    [[ "$ANS" == "y" || "$ANS" == "Y" ]]
}

# --- Process each file ---
for FILE in "${FILES[@]}"; do
    if [[ ! -f "$FILE" ]]; then
        err "File not found: $FILE"
        continue
    fi

    BASE=$(basename "$FILE")
    BASE="${BASE%.*}"
    EXT="${FILE##*.}"
    EXT="${EXT,,}"  # lowercase

    EXTRACT="$EXTRACTS_DIR/${BASE}.txt"

    echo -e "\n${BLUE}Processing:${NC} $(basename "$FILE")"

    # --- Step 1: extract text ---
    if [[ $DO_TXT -eq 1 ]]; then
        case "$EXT" in
            pdf)
                if [[ $DRYRUN -eq 1 ]]; then
                    echo "  [dry-run] pdftotext -layout $FILE -> $EXTRACT"
                elif should_write "$EXTRACT"; then
                    echo -n "  [1] Extracting text... "
                    pdftotext -layout "$FILE" "$EXTRACT"
                    if [[ $? -ne 0 ]]; then
                        echo ""
                        err "pdftotext failed for $FILE"
                        continue
                    fi
                    ok "-> $(basename "$EXTRACT")"
                fi
                ;;
            txt|md|text)
                if [[ "$FILE" == "$EXTRACT" ]]; then
                    echo "  [1] Already in Extracts: $(basename "$EXTRACT")"
                elif [[ $DRYRUN -eq 1 ]]; then
                    echo "  [dry-run] cp $FILE -> $EXTRACT"
                elif should_write "$EXTRACT"; then
                    echo -n "  [1] Copying extract... "
                    cp "$FILE" "$EXTRACT"
                    ok "-> $(basename "$EXTRACT")"
                fi
                ;;
            *)
                warn "Unsupported file type for extraction: .$EXT -- skipping extract step"
                ;;
        esac
    fi

    # --- Step 2: generate summary ---
    if [[ $DO_SUMMARY -eq 1 ]]; then
        SUMMARY="$SUMMARIES_DIR/summary_${BASE}.md"

        # Determine source text
        SOURCE=""
        [[ -f "$EXTRACT" ]] && SOURCE="$EXTRACT"
        if [[ -z "$SOURCE" && "$EXT" != "pdf" ]]; then
            SOURCE="$FILE"
        fi

        if [[ -z "$SOURCE" ]]; then
            warn "No text source for $BASE -- run with --txt first or provide a .txt input"
            continue
        fi

        if [[ $DRYRUN -eq 1 ]]; then
            echo "  [dry-run] claude -p --model $MODEL < $SOURCE -> $SUMMARY"
            echo "  [dry-run] prompt: $PROMPT_LABEL"
            continue
        fi

        if ! should_write "$SUMMARY"; then
            continue
        fi

        # Build prompt text
        if [[ -n "$PROMPT_FILE" ]]; then
            PROMPT_TEXT=$(cat "$PROMPT_FILE")
        else
            PROMPT_TEXT="$DEFAULT_PROMPT"
        fi

        JSON_OUT=$(mktemp /tmp/summary_json.XXXXXX)
        TMPFILE=$(mktemp /tmp/summary_content.XXXXXX)

        # Run claude with JSON output (provides cost + token usage)
        {
            printf '%s\n\n' "$PROMPT_TEXT"
            cat "$SOURCE"
        } | claude -p --output-format json --model "$MODEL" > "$JSON_OUT" &
        BGPID=$!

        # Live elapsed-time counter (terminal only)
        STEP=$([[ $DO_TXT -eq 1 ]] && echo 2 || echo 1)
        T_START=$(date +%s)
        if [[ -t 1 ]]; then
            while kill -0 "$BGPID" 2>/dev/null; do
                ELAPSED=$(( $(date +%s) - T_START ))
                printf "\r  [%s] Generating summary (%s)... %d:%02d" \
                    "$STEP" "$MODEL" $((ELAPSED / 60)) $((ELAPSED % 60))
                sleep 1
            done
            printf "\r%-72s\r" ""  # clear line
        else
            echo "  [$STEP] Generating summary ($MODEL)..."
        fi

        wait "$BGPID"
        CLAUDE_EXIT=$?

        if [[ $CLAUDE_EXIT -ne 0 || ! -s "$JSON_OUT" ]]; then
            err "Summary generation failed for $BASE"
            rm -f "$JSON_OUT" "$TMPFILE"
            continue
        fi

        # Parse JSON: extract result text and usage stats
        STATS=$(python3 - "$JSON_OUT" "$TMPFILE" <<'PYEOF'
import json, sys
json_file, text_file = sys.argv[1], sys.argv[2]
with open(json_file) as f:
    data = json.load(f)
with open(text_file, 'w') as f:
    f.write(data.get('result', ''))
u = data.get('usage', {})
api_ms  = data.get('duration_api_ms', data.get('duration_ms', 0))
cost    = data.get('total_cost_usd', 0)
in_tok  = u.get('input_tokens', 0)
out_tok = u.get('output_tokens', 0)
err     = data.get('is_error', False)
print(f"{cost:.6f} {in_tok} {out_tok} {api_ms} {err}")
PYEOF
)
        rm -f "$JSON_OUT"

        read -r COST INPUT_TOKENS OUTPUT_TOKENS API_MS IS_ERROR <<< "$STATS"
        API_SEC=$(( ${API_MS%.*} / 1000 ))

        if [[ "$IS_ERROR" == "True" || ! -s "$TMPFILE" ]]; then
            err "Summary generation failed for $BASE"
            rm -f "$TMPFILE"
            continue
        fi

        # Write YAML frontmatter + generated content
        {
            printf -- '---\n'
            printf 'source: %s\n'        "$(basename "$SOURCE")"
            printf 'prompt: %s\n'        "$PROMPT_LABEL"
            printf 'model: %s\n'         "$MODEL"
            printf 'elapsed: %d:%02d\n'  $((API_SEC / 60)) $((API_SEC % 60))
            printf 'cost_usd: %s\n'      "$COST"
            printf 'input_tokens: %s\n'  "$INPUT_TOKENS"
            printf 'output_tokens: %s\n' "$OUTPUT_TOKENS"
            printf 'generated: %s\n'     "$(date +%Y-%m-%d)"
            printf -- '---\n\n'
            cat "$TMPFILE"
        } > "$SUMMARY"

        rm -f "$TMPFILE"
        ok "[$STEP] Summary -> $(basename "$SUMMARY") (${API_SEC}s, \$${COST}, ${INPUT_TOKENS}+${OUTPUT_TOKENS} tok)"
    fi
done
